{
  "name": "jclaw",
  "version": "1.0.0",
  "description": "JCLAW (Jules Crustacean Logic & Automated Workflow): An MCP server for high-level Jules orchestration using the Lobster pattern.",
  "mcpServers": {
    "jclaw": {
      "command": "node",
      "args": ["dist/index.js"],
      "env": {
        "HEADLESS": "true",
        "SESSION_MODE": "browserbase"
      }
    }
  },
  "commands": {
    "jclaw.delegate": "commands/jclaw/delegate.toml",
    "jclaw.status": "commands/jclaw/status.toml",
    "jclaw.audit": "commands/jclaw/audit.toml",
    "jclaw.conclude": "commands/jclaw/conclude.toml",
    "jclaw.review": "commands/jclaw/review.toml",
    "jclaw.feedback": "commands/jclaw/feedback.toml",
    "jclaw.dependency": "commands/jclaw/dependency.toml",
    "jclaw.resolve": "commands/jclaw/resolve.toml",
    "jclaw.sync": "commands/jclaw/sync.toml"
  }
}
